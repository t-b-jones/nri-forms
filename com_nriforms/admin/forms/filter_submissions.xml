<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="NRI\Component\Nriforms\Site\Field">
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="JSEARCH_FILTER"
            hint="JSEARCH_FILTER"
        />
        <field
            name="group_id"
            type="formgroup"
            label="COM_NRIFORMS_FIELD_FORM_LABEL"
            onchange="this.form.submit();"
        >
            <option value="">COM_NRIFORMS_FILTER_SELECT_FORM</option>
        </field>
    </fields>
    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.created DESC"
            onchange="this.form.submit();"
            validate="options"
        >
            <option value="a.created DESC">JDATE_DESC</option>
            <option value="a.created ASC">JDATE_ASC</option>
            <option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
            <option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
        </field>
        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
