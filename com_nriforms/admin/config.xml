<?xml version="1.0" encoding="utf-8"?>
<config>
    <fieldset name="general" label="COM_NRIFORMS_CONFIG_GENERAL_LABEL">
        <field
            name="default_recipient"
            type="email"
            label="COM_NRIFORMS_CONFIG_DEFAULT_RECIPIENT_LABEL"
            description="COM_NRIFORMS_CONFIG_DEFAULT_RECIPIENT_DESC"
            validate="email"
        />
        <field
            name="save_submissions"
            type="radio"
            layout="joomla.form.field.radio.switcher"
            label="COM_NRIFORMS_CONFIG_SAVE_SUBMISSIONS_LABEL"
            default="1"
            filter="integer"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>
    <fieldset name="permissions" label="JCONFIG_PERMISSIONS_LABEL" description="JCONFIG_PERMISSIONS_DESC">
        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL" filter="rules" component="com_nriforms" section="component" />
    </fieldset>
</config>
