<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>COM_NRIFORMS</name>
    <author>Tom / NRI Web</author>
    <creationDate>2026-07</creationDate>
    <copyright>(C) 2026 Natural Resources Institute</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>1.1.0</version>
    <description>COM_NRIFORMS_XML_DESCRIPTION</description>

    <namespace path="src">NRI\Component\Nriforms</namespace>


    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>
    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <files folder="site">
        <folder>language</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <languages folder="site/language">
        <language tag="en-GB">en-GB/com_nriforms.ini</language>
    </languages>

    <administration>
        <menu img="class:checkbox-partial">COM_NRIFORMS_MENU</menu>
        <submenu>
            <menu link="option=com_nriforms&amp;view=forms" img="class:checkbox-partial">COM_NRIFORMS_MENU_FORMS</menu>
            <menu link="option=com_nriforms&amp;view=submissions" img="class:checkbox-partial">COM_NRIFORMS_MENU_SUBMISSIONS</menu>
            <menu link="option=com_fields&amp;context=com_nriforms.form&amp;view=fields" img="class:checkbox-partial">JGLOBAL_FIELDS</menu>
            <menu link="option=com_fields&amp;context=com_nriforms.form&amp;view=groups" img="class:checkbox-partial">JGLOBAL_FIELD_GROUPS</menu>
        </submenu>
        <files folder="admin">
            <folder>forms</folder>
            <folder>language</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
            <filename>access.xml</filename>
            <filename>config.xml</filename>
        </files>
        <languages folder="admin/language">
            <language tag="en-GB">en-GB/com_nriforms.ini</language>
            <language tag="en-GB">en-GB/com_nriforms.sys.ini</language>
        </languages>
    </administration>
</extension>
